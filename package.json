{
  "name": "sprite-editor-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter editor dev",
    "build": "pnpm --filter editor build && pnpm --filter @msviderok/sprite-editor-vite build",
    "dev:playground": "pnpm --filter @msviderok/sprite-editor-vite build && pnpm --filter plugin-playground dev",
    "build:playground": "pnpm --filter @msviderok/sprite-editor-vite build && pnpm --filter plugin-playground build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@10.33.0"
}
